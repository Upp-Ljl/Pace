# Pace landing site is just the 3 files at repo root:
#   index.html / styles.css / app.js
# Everything else is the Electron app + docs that Vercel doesn't need.

packages/
_reference-from-cairn/
.pace-push-token/
.git/
node_modules/

# Markdown docs (kept in repo, not served from landing site)
*.md
!index.html

# Source / native code
*.cjs
*.mjs
*.node

# Electron / SQLite build artifacts
build/
dist/
out/

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs / temp
*.log
.tmp/

# Demo video + BGM artifacts (kept in repo, not served from landing)
# Only block docs/*.mp4 — root pace-demo.mp4 IS served by the landing site.
docs/*.mp4
*.mp3
docs/bgm-candidates/
docs/
.shots/
